-- CONTROL PIGGY BOT (AI OFF + FULL ANIMATION FIX)
--------------------------------------------------

local controllingPiggy = false
local controlConnection

local piggy
local piggyRoot
local humanoid
local bodyVelocity

createButton("Control Piggy: OFF", function(button)

    controllingPiggy = not controllingPiggy

    if controllingPiggy then
        button.Text = "Control Piggy: ON"
        button.TextColor3 = Color3.fromRGB(0,255,0)

        --------------------------------------------------
        -- FIND PIGGY
        --------------------------------------------------
        local piggyFolder = workspace:FindFirstChild("PiggyNPC")
        piggy = piggyFolder and piggyFolder:FindFirstChildWhichIsA("Model")

        if not piggy then
            warn("Piggy not found")
            controllingPiggy = false
            return
        end

        piggyRoot = piggy:FindFirstChild("HumanoidRootPart")
        humanoid = piggy:FindFirstChildOfClass("Humanoid")

        if not piggyRoot or not humanoid then return end

        --------------------------------------------------
        -- CAMERA
        --------------------------------------------------
        workspace.CurrentCamera.CameraSubject = humanoid

        --------------------------------------------------
        -- DISABLE PLAYER
        --------------------------------------------------
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.WalkSpeed = 0
            char.Humanoid.JumpPower = 0
        end

        --------------------------------------------------
        -- AI OFF & PREP MOVEMENT
        --------------------------------------------------
        humanoid:ChangeState(Enum.HumanoidStateType.Physics)
        humanoid.AutoRotate = false

        -- create BodyVelocity to control humanoid without Physics glitches
        bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.MaxForce = Vector3.new(1e5, 0, 1e5)
        bodyVelocity.Velocity = Vector3.zero
        bodyVelocity.P = 1e4
        bodyVelocity.Parent = piggyRoot

        --------------------------------------------------
        -- CONTROL LOOP
        --------------------------------------------------
        controlConnection = RunService.RenderStepped:Connect(function(dt)
            if not piggyRoot or not humanoid then return end

            local cam = workspace.CurrentCamera
            local moveDir = Vector3.zero

            if UIS:IsKeyDown(Enum.KeyCode.W) then
                moveDir += cam.CFrame.LookVector
            end
            if UIS:IsKeyDown(Enum.KeyCode.S) then
                moveDir -= cam.CFrame.LookVector
            end
            if UIS:IsKeyDown(Enum.KeyCode.A) then
                moveDir -= cam.CFrame.RightVector
            end
            if UIS:IsKeyDown(Enum.KeyCode.D) then
                moveDir += cam.CFrame.RightVector
            end

            moveDir = Vector3.new(moveDir.X, 0, moveDir.Z)

            local speed = 18
            if moveDir.Magnitude > 0 then
                moveDir = moveDir.Unit

                -- BodyVelocity handles movement
                bodyVelocity.Velocity = moveDir * speed

                -- Rotate humanoid
                piggyRoot.CFrame = CFrame.lookAt(piggyRoot.Position, piggyRoot.Position + moveDir)

                -- Fake MoveDirection for animations
                humanoid:Move(moveDir, false)
            else
                -- Stop movement
                bodyVelocity.Velocity = Vector3.zero
                humanoid:Move(Vector3.zero, false)

                -- Reset Animator to properly trigger idle
                if humanoid:FindFirstChild("Animator") then
                    for _, track in ipairs(humanoid.Animator:GetPlayingAnimationTracks()) do
                        track:Stop(0.1)
                    end
                end
            end

            -- Ensure AI remains dead
            if humanoid:GetState() ~= Enum.HumanoidStateType.Physics then
                humanoid:ChangeState(Enum.HumanoidStateType.Physics)
            end
        end)

    else
        --------------------------------------------------
        -- TURN OFF
        --------------------------------------------------
        button.Text = "Control Piggy: OFF"
        button.TextColor3 = Color3.fromRGB(255,255,255)

        if controlConnection then
            controlConnection:Disconnect()
            controlConnection = nil
        end

        if bodyVelocity then
            bodyVelocity:Destroy()
            bodyVelocity = nil
