local playerESPEnabled = false
local playerTracked = {}

createButton("Player ESP: OFF", function(button)

    playerESPEnabled = not playerESPEnabled

    button.Text = playerESPEnabled and "Player ESP: ON" or "Player ESP: OFF"
    button.TextColor3 = playerESPEnabled and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)

    if not playerESPEnabled then return end

    local GREEN = Color3.fromRGB(0,255,0)
    local RED   = Color3.fromRGB(255,0,0)

    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer

    local function apply(character, player)
        if not character or not character:FindFirstChild("HumanoidRootPart") then
            return
        end

        if playerTracked[character] then return end
        playerTracked[character] = true

        local function updateESP()
            if not playerESPEnabled then return end

            local color = GREEN
            local label = player.Name

            -- Piggy (Enemy)
            local enemy = character:FindFirstChild("Enemy")
            if enemy and enemy:IsA("BoolValue") and enemy.Value == true then
                color = RED
            end

            -- Traitor (priority over normal name)
            local traitor = character:FindFirstChild("Traitor")
            if traitor and traitor:IsA("BoolValue") and traitor.Value == true then
                color = RED
                label = "TRAITOR"
            end

            highlightTarget(character, color)
            createTracer(character, color)
            createNameTag(character, label, color)
        end

        updateESP()

        local enemy = character:FindFirstChild("Enemy")
        if enemy and enemy:IsA("BoolValue") then
            enemy:GetPropertyChangedSignal("Value"):Connect(updateESP)
        end

        local traitor = character:FindFirstChild("Traitor")
        if traitor and traitor:IsA("BoolValue") then
            traitor:GetPropertyChangedSignal("Value"):Connect(updateESP)
        end
    end

    -- Constant detection loop
    task.spawn(function()
        while playerESPEnabled do
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then
                    local char = player.Character
                    if char then
                        apply(char, player)
                    end
                end
            end
            task.wait(1)
        end
    end)

    -- Instant detection for new players
    Players.PlayerAdded:Connect(function(player)
        player.CharacterAdded:Connect(function(char)
            task.wait(0.5)
            apply(char, player)
        end)
    end)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            player.CharacterAdded:Connect(function(char)
                task.wait(0.5)
                apply(char, player)
            end)
        end
    end

end)


