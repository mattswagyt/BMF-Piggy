-- ITEM ESP (SMART + AUTO DETECT + TOGGLE)
--------------------------------------------------

local itemESPEnabled = false

createButton("Item ESP: OFF", function(button)

    itemESPEnabled = not itemESPEnabled

    button.Text = itemESPEnabled and "Item ESP: ON" or "Item ESP: OFF"
    button.TextColor3 = itemESPEnabled and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)

    if not itemESPEnabled then return end

    local trackedFolder = nil
    local originalNames = {} -- [instance] = original name

    --------------------------------------------------
    -- Get item color safely
    --------------------------------------------------
    local function getItemColor(item)
        if item:IsA("BasePart") or item:IsA("UnionOperation") then
            return item.Color
        end
        return Color3.fromRGB(255,255,255)
    end

    --------------------------------------------------
    -- Apply ESP
    --------------------------------------------------
    local function apply(item)

        if not itemESPEnabled then return end
        if not originalNames[item] then return end

        local color = getItemColor(item)
        local name = originalNames[item]

        highlightTarget(item, color)
        createTracer(item, color)
        createNameTag(item, name, color)

    end

    --------------------------------------------------
    -- Scan for ORIGINAL ItemFolder
    --------------------------------------------------
    task.spawn(function()

        while itemESPEnabled do
            task.wait(1)

            -- Step 1: Find original ItemFolder BEFORE rename
            if not trackedFolder then
                for _, obj in ipairs(workspace:GetChildren()) do
                    if obj:IsA("Folder") and obj.Name == "ItemFolder" then
                        trackedFolder = obj

                        -- Cache ORIGINAL item names
                        for _, item in ipairs(obj:GetChildren()) do
                            if item:IsA("BasePart") or item:IsA("UnionOperation") then
                                originalNames[item] = item.Name
                            end
                        end

                        -- Track new items BEFORE rename
                        obj.ChildAdded:Connect(function(item)
                            task.wait()
                            if item:IsA("BasePart") or item:IsA("UnionOperation") then
                                originalNames[item] = item.Name
                            end
                        end)
                    end
                end
            end

            -- Step 2: If folder exists (even renamed), apply ESP
            if trackedFolder and trackedFolder.Parent then

                for _, item in ipairs(trackedFolder:GetChildren()) do
                    if (item:IsA("BasePart") or item:IsA("UnionOperation")) then
                        apply(item)
                    end
                end

            else
                -- Reset for next round
                trackedFolder = nil
                originalNames = {}
            end

        end

    end)

end)


