task.spawn(function()

    while true do

        local found=false

        for _,player in pairs(Players:GetPlayers()) do

            local model=workspace:FindFirstChild(player.Name)

            if model then

                local traitor=model:FindFirstChild("Traitor")

                if traitor and traitor.Value==true then

                    TraitorLabel.Text="Traitor: "..player.Name
                    found=true
                    break

                end

            end

        end

        if not found then
            TraitorLabel.Text="Traitor: It is not in traitor mode, or traitor not found."
        end

        task.wait(0.5)

    end

end)

