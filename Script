createButton("God Mode", function()

    local folder = workspace:FindFirstChild("PiggyNPC")
    if not folder then return end

    local trackedBots = {}

    local function neuter(bot)
        if not bot or not bot.Parent then return end

        -- Force Enemy false
        local enemy = bot:FindFirstChild("Enemy")
        if enemy and enemy:IsA("BoolValue") then
            enemy.Value = false
        end

        -- Destroy only specified paths
        for _, part in ipairs(bot:GetDescendants()) do
            if part:IsA("TouchTransmitter") or part.Name == "TouchInterest" then
                part:Destroy()
            end
        end
    end

    local function trackBot(bot)
        if trackedBots[bot] then return end
        trackedBots[bot] = true

        -- Initial neuter
        neuter(bot)

        -- If new descendants are added later
        bot.DescendantAdded:Connect(function(obj)
            if obj:IsA("TouchTransmitter") or obj.Name == "TouchInterest" then
                obj:Destroy()
            end
        end)

        -- If Enemy value is re-added or flipped
        bot.ChildAdded:Connect(function(child)
            if child.Name == "Enemy" and child:IsA("BoolValue") then
                child.Value = false
            end
        end)
    end

    -- Track existing bots
    for _, bot in ipairs(folder:GetChildren()) do
        trackBot(bot)
    end

    -- Track new bots (Swarm support)
    folder.ChildAdded:Connect(function(bot)
        trackBot(bot)
    end)

    -- Continuous enforcement loop (important)
    task.spawn(function()
        while folder.Parent do
            for _, bot in ipairs(folder:GetChildren()) do
                neuter(bot)
            end
            task.wait(0.5)
        end
    end)

end)

