createButton("Player ESP", function()

    local GREEN = Color3.fromRGB(0,255,0)
    local RED   = Color3.fromRGB(255,0,0)

    local function apply(character, player)
        if not character or not character:FindFirstChild("HumanoidRootPart") then
            return
        end

        local color = GREEN

        -- Check for Enemy value under character
        local enemy = character:FindFirstChild("Enemy")
        if enemy and enemy:IsA("BoolValue") and enemy.Value == true then
            color = RED
        end

        highlightTarget(character, color)
        createTracer(character, color)
        createNameTag(character, player.Name, color)

        -- If Enemy value changes while playing
        if enemy and enemy:IsA("BoolValue") then
            enemy:GetPropertyChangedSignal("Value"):Connect(function()
                local newColor = enemy.Value and RED or GREEN
                highlightTarget(character, newColor)
                createTracer(character, newColor)
                createNameTag(character, player.Name, newColor)
            end)
        end
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then

            if player.Character then
                apply(player.Character, player)
            end

            player.CharacterAdded:Connect(function(char)
                task.wait(1)
                apply(char, player)
            end)

        end
    end

end)

