--------------------------------------------------
-- God Mode (TOGGLE - UNIFIED + NO STACKED CONNECTIONS)
--------------------------------------------------

local godModeEnabled = false
local tracked = {} -- central registry for all models

createButton("God Mode: OFF", function(button)
    if not button then return end

    godModeEnabled = not godModeEnabled

    button.Text = godModeEnabled and "God Mode: ON" or "God Mode: OFF"
    button.TextColor3 = godModeEnabled and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)

    if not godModeEnabled then return end

    --------------------------------------------------
    -- CENTRAL NEUTER FUNCTION
    --------------------------------------------------
    local function neuter(model, isGrandmother)
        if not model or not model.Parent then return end
        local enemy = model:FindFirstChild("Enemy")
        if enemy and enemy:IsA("BoolValue") then
            enemy.Value = false
        end

        for _, v in ipairs(model:GetDescendants()) do
            if v:IsA("TouchTransmitter") or v.Name == "TouchInterest" then
                v:Destroy()
            end
        end

        if isGrandmother then
            local head = model:FindFirstChild("Head")
            if head then
                for _, v in ipairs(head:GetDescendants()) do
                    if v:IsA("TouchTransmitter") or v.Name == "TouchInterest" then
                        v:Destroy()
                    end
                end
            end
        end
    end

    --------------------------------------------------
    -- SINGLE TRACK FUNCTION
    --------------------------------------------------
    local function track(model, isGrandmother)
        if not godModeEnabled then return end
        if tracked[model] then return end
        tracked[model] = true

        neuter(model, isGrandmother)

        -- unified descendant tracking
        model.DescendantAdded:Connect(function(obj)
            if not godModeEnabled then return end
            if obj:IsA("TouchTransmitter") or obj.Name == "TouchInterest" then
                obj:Destroy()
            end
        end)

        -- unified child tracking
        model.ChildAdded:Connect(function(child)
            if not godModeEnabled then return end
            if child.Name == "Enemy" and child:IsA("BoolValue") then
                child.Value = false
            end
        end)

        -- continuous enforcement
        task.spawn(function()
            while model.Parent and godModeEnabled do
                neuter(model, isGrandmother)
                task.wait()
            end
        end)
    end

    --------------------------------------------------
    -- UNIFIED FOLDER TRACKER
    --------------------------------------------------
    local function trackFolder(folder, isGrandmother)
        if not folder then return end
        for _, obj in ipairs(folder:GetChildren()) do
            if obj:IsA("Model") then
                track(obj, isGrandmother)
            end
        end

        folder.ChildAdded:Connect(function(obj)
            if obj:IsA("Model") then
                track(obj, isGrandmother)
            end
        end)
    end

    --------------------------------------------------
    -- AUTOMATIC MAP DETECTION
    --------------------------------------------------
    local function autoDetectMap(mapName, headName, isGrandmother)
        local map = workspace:FindFirstChild(mapName)
        if not map then return end

        local function handle(obj)
            if not obj:IsA("Model") then return end
            if obj:FindFirstChild("Enemy") or obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild(headName, true) then
                track(obj, isGrandmother)
            end
        end

        -- handle existing
        for _, obj in ipairs(map:GetDescendants()) do
            handle(obj)
        end

        -- handle new
        map.DescendantAdded:Connect(handle)
    end

    autoDetectMap("City", "PiggyHead", true)
    autoDetectMap("Carnival", "FoxyHead", false)
    autoDetectMap("Forest", "DogHead", false)

    --------------------------------------------------
    -- MR P PROJECTILES
    --------------------------------------------------
    local function handleMrP(obj)
        if obj.Name ~= "HomingProjectile" then return end
        for _, v in ipairs(obj:GetDescendants()) do
            if v:IsA("TouchTransmitter") or v.Name == "TouchInterest" then
                v:Destroy()
            end
        end
    end

    local function trackPlant()
        local plant = workspace:FindFirstChild("Plant")
        if not plant then return end
        for _, obj in ipairs(plant:GetDescendants()) do
            handleMrP(obj)
        end
        plant.DescendantAdded:Connect(handleMrP)
    end

    trackPlant()

    --------------------------------------------------
    -- MALL LASERS
    --------------------------------------------------
    local function handleLasers(container)
        for _, v in ipairs(container:GetDescendants()) do
            if v:IsA("Model") and v.Name == "Lasers" then
                v:Destroy()
            end
        end
        container.DescendantAdded:Connect(function(v)
            if v:IsA("Model") and v.Name == "Lasers" then
                v:Destroy()
            end
        end)
    end

    local function trackMall()
        local loaded = workspace:FindFirstChild("LoadedMap")
        if loaded and loaded:FindFirstChild("Part1") then
            local jail = loaded.Part1:FindFirstChild("JailbreakEvent")
            if jail then
                handleLasers(jail)
            end
        end
    end

    if workspace:FindFirstChild("Mall") then
        trackMall()
    end
    workspace.ChildAdded:Connect(function(child)
        if child.Name == "Mall" then
            task.wait(0.2)
            trackMall()
        end
    end)

    --------------------------------------------------
    -- PIGGYNPC
    --------------------------------------------------
    local function trackPiggyNPC()
        local piggyFolder = workspace:FindFirstChild("PiggyNPC")
        if not piggyFolder then return end
        for _, bot in ipairs(piggyFolder:GetChildren()) do
            if bot:IsA("Model") then
                track(bot, false)
            end
        end
        piggyFolder.ChildAdded:Connect(function(bot)
            if bot:IsA("Model") then
                track(bot, false)
            end
        end)
    end

    trackPiggyNPC()

    --------------------------------------------------
    -- OUTPOST TRACKING
    --------------------------------------------------
    local function trackOutpost()
        local outpost = workspace:FindFirstChild("Outpost")
        if not outpost then return end
        for _, folder in ipairs(outpost:GetChildren()) do
            if folder:IsA("Folder") then
                for _, model in ipairs(folder:GetChildren()) do
                    track(model, false)
                end
                folder.ChildAdded:Connect(function(model)
                    track(model, false)
                end)
            end
        end
    end

    trackOutpost()

    --------------------------------------------------
    -- GLOBAL ENFORCEMENT LOOP
    --------------------------------------------------
    task.spawn(function()
        while godModeEnabled do
            -- Re-run map detection (safe, no duplicate connections)
            autoDetectMap("City", "PiggyHead", true)
            autoDetectMap("Carnival", "FoxyHead", false)
            autoDetectMap("Forest", "DogHead", false)

            -- Mr P
            trackPlant()

            -- PiggyNPC
            trackPiggyNPC()

            -- Mall lasers
            trackMall()

            -- Outpost
            trackOutpost()

            task.wait(0.5) -- slightly less frequent, less CPU
        end
    end)
end)


