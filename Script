createButton("God Mode", function()

    local tracked = {}

    --------------------------------------------------
    -- BASE NEUTER
    --------------------------------------------------
    local function neuter(model)
        if not model or not model.Parent then return end

        local enemy = model:FindFirstChild("Enemy")
        if enemy and enemy:IsA("BoolValue") then
            enemy.Value = false
        end

        for _, v in ipairs(model:GetDescendants()) do
            if v:IsA("TouchTransmitter") or v.Name == "TouchInterest" then
                v:Destroy()
            end
        end
    end

    --------------------------------------------------
    -- TRACK MODEL (GENERIC)
    --------------------------------------------------
    local function track(model)
        if tracked[model] then return end
        tracked[model] = true

        neuter(model)

        model.DescendantAdded:Connect(function(obj)
            if obj:IsA("TouchTransmitter") or obj.Name == "TouchInterest" then
                obj:Destroy()
            end
        end)

        model.ChildAdded:Connect(function(child)
            if child.Name == "Enemy" and child:IsA("BoolValue") then
                child.Value = false
            end
        end)
    end

    --------------------------------------------------
    -- TRACK FOLDER RECURSIVELY
    --------------------------------------------------
    local function trackFolder(folder)
        if not folder then return end

        -- Track existing
        for _, obj in ipairs(folder:GetChildren()) do
            if obj:IsA("Model") then
                track(obj)
            end
        end

        -- Track new
        folder.ChildAdded:Connect(function(obj)
            if obj:IsA("Model") then
                track(obj)
            end
        end)
    end

    --------------------------------------------------
    -- PIGGYNPC (SWARM)
    --------------------------------------------------
    local piggyFolder = workspace:FindFirstChild("PiggyNPC")
    if piggyFolder then

        local function hardNeuter(model)
            if not model or not model.Parent then return end

            local enemy = model:FindFirstChild("Enemy")
            if enemy and enemy:IsA("BoolValue") then
                enemy.Value = false
            end

            for _, v in ipairs(model:GetDescendants()) do
                if v:IsA("TouchTransmitter") or v.Name == "TouchInterest" then
                    v:Destroy()
                end
            end
        end

        local function trackBot(bot)
            if not bot:IsA("Model") then return end

            -- Initial neuter
            hardNeuter(bot)

            -- Instant descendant / Enemy hooks
            bot.DescendantAdded:Connect(function(obj)
                if obj:IsA("TouchTransmitter") or obj.Name == "TouchInterest" then
                    obj:Destroy()
                end
            end)

            bot.ChildAdded:Connect(function(child)
                if child.Name == "Enemy" and child:IsA("BoolValue") then
                    child.Value = false
                end
            end)

            -- CONSTANT LOOP
            task.spawn(function()
                while bot.Parent do
                    hardNeuter(bot)
                    task.wait()
                end
            end)
        end

        for _, bot in ipairs(piggyFolder:GetChildren()) do
            trackBot(bot)
        end

        piggyFolder.ChildAdded:Connect(trackBot)
    end

    --------------------------------------------------
    -- OUTPOST (SOLDIERS)
    --------------------------------------------------
    local outpost = workspace:FindFirstChild("Outpost")
    if outpost then
        for _, folder in ipairs(outpost:GetChildren()) do
            if folder:IsA("Folder") then
                trackFolder(folder)

                -- Constant loop for each model in folder
                for _, model in ipairs(folder:GetChildren()) do
                    task.spawn(function()
                        while model.Parent do
                            neuter(model)
                            task.wait()
                        end
                    end)
                end
            end
        end

        outpost.ChildAdded:Connect(function(folder)
            if folder:IsA("Folder") then
                trackFolder(folder)

                for _, model in ipairs(folder:GetChildren()) do
                    task.spawn(function()
                        while model.Parent do
                            neuter(model)
                            task.wait()
                        end
                    end)
                end
            end
        end)
    end

    --------------------------------------------------
    -- MAP TARGET TRACKER (Grandmother / Foxy / Doggy)
    --------------------------------------------------
    local function trackMap(mapName, headName, destroyHead)
        local map = workspace:FindFirstChild(mapName)
        if not map then return end

        local function checkModel(model)
            if not model:IsA("Model") then return end

            if model:FindFirstChild(headName, true) then
                track(model)

                if destroyHead then
                    local head = model:FindFirstChild("Head")
                    if head then head:Destroy() end
                end

                -- CONSTANT LOOP
                task.spawn(function()
                    while model.Parent do
                        neuter(model)
                        task.wait()
                    end
                end)
            end
        end

        for _, folder in ipairs(map:GetChildren()) do
            if folder:IsA("Folder") then
                for _, model in ipairs(folder:GetChildren()) do
                    checkModel(model)
                end

                folder.ChildAdded:Connect(checkModel)
            end
        end

        map.ChildAdded:Connect(function(folder)
            if folder:IsA("Folder") then
                for _, model in ipairs(folder:GetChildren()) do
                    checkModel(model)
                end
                folder.ChildAdded:Connect(checkModel)
            end
        end)
    end

    trackMap("City", "PiggyHead", true)
    trackMap("Carnival", "FoxyHead", false)
    trackMap("Forest", "DogHead", false)

    --------------------------------------------------
    -- MALL LASERS
    --------------------------------------------------
    local function handleLasers(container)
        for _, v in ipairs(container:GetDescendants()) do
            if v:IsA("Model") and v.Name == "Lasers" then
                v:Destroy()
            end
        end

        container.DescendantAdded:Connect(function(v)
            if v:IsA("Model") and v.Name == "Lasers" then
                v:Destroy()
            end
        end)

        -- CONSTANT LOOP (keep removing if server respawns)
        task.spawn(function()
            while container.Parent do
                for _, v in ipairs(container:GetDescendants()) do
                    if v:IsA("Model") and v.Name == "Lasers" then
                        v:Destroy()
                    end
                end
                task.wait()
            end
        end)
    end

    local function trackMall()
        local mall = workspace:FindFirstChild("Mall")
        if not mall then return end

        local loaded = workspace:FindFirstChild("LoadedMap")
        if loaded and loaded:FindFirstChild("Part1") then
            local jail = loaded.Part1:FindFirstChild("JailbreakEvent")
            if jail then
                handleLasers(jail)
            end
        end
    end

    trackMall()
    workspace.ChildAdded:Connect(function(child)
        if child.Name == "Mall" then
            task.wait(0.2)
            trackMall()
        end
    end)

end)

