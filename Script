createButton("Player ESP", function()

    local GREEN = Color3.fromRGB(0,255,0)
    local RED   = Color3.fromRGB(255,0,0)

    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer

    local tracked = {}

    local function apply(character, player)
        if not character or not character:FindFirstChild("HumanoidRootPart") then
            return
        end

        -- Prevent reapplying ESP multiple times
        if tracked[character] then return end
        tracked[character] = true

        local function updateESP()
            local color = GREEN
            local label = player.Name

            -- Piggy (Enemy)
            local enemy = character:FindFirstChild("Enemy")
            if enemy and enemy:IsA("BoolValue") and enemy.Value == true then
                color = RED
            end

            -- Traitor (priority over normal name)
            local traitor = character:FindFirstChild("Traitor")
            if traitor and traitor:IsA("BoolValue") and traitor.Value == true then
                color = RED
                label = "TRAITOR"
            end

            highlightTarget(character, color)
            createTracer(character, color)
            createNameTag(character, label, color)
        end

        -- Initial apply
        updateESP()

        -- Listen for Enemy changes
        local enemy = character:FindFirstChild("Enemy")
        if enemy and enemy:IsA("BoolValue") then
            enemy:GetPropertyChangedSignal("Value"):Connect(updateESP)
        end

        -- Listen for Traitor changes
        local traitor = character:FindFirstChild("Traitor")
        if traitor and traitor:IsA("BoolValue") then
            traitor:GetPropertyChangedSignal("Value"):Connect(updateESP)
        end
    end

    -- Constant player detection loop
    task.spawn(function()
        while true do
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then
                    local char = player.Character
                    if char then
                        apply(char, player)
                    end
                end
            end
            task.wait(1) -- adjust if you want faster detection
        end
    end)

    -- Also hook CharacterAdded for instant response
    Players.PlayerAdded:Connect(function(player)
        player.CharacterAdded:Connect(function(char)
            task.wait(0.5)
            apply(char, player)
        end)
    end)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            player.CharacterAdded:Connect(function(char)
                task.wait(0.5)
                apply(char, player)
            end)
        end
    end

end)

