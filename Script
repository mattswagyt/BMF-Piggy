createButton("Soldiers Ignore You", function()

    local outpost = workspace:FindFirstChild("Outpost")
    if not outpost then
        ErrorLog.Text = "Error Log: Outpost not found"
        return
    end

    local tracked = {}

    --------------------------------------------------
    -- Disable soldier damage
    --------------------------------------------------

    local function neuter(model)

        if not model or not model.Parent then return end

        -- Ignore Zizzy model
        if model:FindFirstChild("ZizzyHead", true) then
            return
        end

        -- Must have Enemy value
        local enemy = model:FindFirstChild("Enemy")
        if not enemy or not enemy:IsA("BoolValue") then
            return
        end

        -- Force Enemy false
        enemy.Value = false

        -- Check HumanoidRootPart
        local hrp = model:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        -- Destroy damage touch
        for _,obj in ipairs(hrp:GetChildren()) do
            if obj:IsA("TouchTransmitter") or obj.Name == "TouchInterest" then
                obj:Destroy()
            end
        end

    end

    --------------------------------------------------
    -- Track models
    --------------------------------------------------

    local function track(model)

        if tracked[model] then return end
        tracked[model] = true

        neuter(model)

        -- Remove new damage triggers instantly
        model.DescendantAdded:Connect(function(obj)
            if obj:IsA("TouchTransmitter") or obj.Name == "TouchInterest" then
                obj:Destroy()
            end
        end)

        -- If Enemy gets re-added
        model.ChildAdded:Connect(function(child)
            if child.Name == "Enemy" and child:IsA("BoolValue") then
                child.Value = false
            end
        end)

    end

    --------------------------------------------------
    -- Scan every folder under Outpost
    --------------------------------------------------

    for _,folder in ipairs(outpost:GetChildren()) do

        if folder:IsA("Folder") then

            for _,model in ipairs(folder:GetChildren()) do
                if model:IsA("Model") then
                    track(model)
                end
            end

            -- Track new models spawning
            folder.ChildAdded:Connect(function(model)
                if model:IsA("Model") then
                    task.wait(0.2)
                    track(model)
                end
            end)

        end

    end

    --------------------------------------------------
    -- Continuous enforcement loop
    --------------------------------------------------

    task.spawn(function()

        while outpost.Parent do

            for _,folder in ipairs(outpost:GetChildren()) do
                if folder:IsA("Folder") then

                    for _,model in ipairs(folder:GetChildren()) do
                        if model:IsA("Model") then
                            neuter(model)
                        end
                    end

                end
            end

            task.wait(0.5)

        end

    end)

end)

