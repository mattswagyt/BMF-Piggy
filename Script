local function createKillPlayerPromptButton()

    local button = Instance.new("TextButton")
    button.Parent = MainFrame
    button.Size = UDim2.new(1,0,0,30)
    button.BackgroundColor3 = Color3.fromRGB(40,40,40)
    button.TextColor3 = Color3.fromRGB(255,255,255)
    button.Font = Enum.Font.SourceSans
    button.TextSize = 16
    button.Text = "Kill Player (Bot Only) [WIP]"

    local promptFrame
    local blurFrame
    local promptOpen = false

    --------------------------------------------------
    -- TELEPORT FIX (NO SNAP BACK + CLOSE RANGE)
    --------------------------------------------------
    local function teleportBotToPlayer(targetPlayer)
        if not targetPlayer then return end

        local character = targetPlayer.Character
        local root = character and character:FindFirstChild("HumanoidRootPart")

        local piggyFolder = workspace:FindFirstChild("PiggyNPC")
        local npc = piggyFolder and piggyFolder:FindFirstChildWhichIsA("Model")

        if not (root and npc) then return end

        local npcRoot = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head")
        if not npcRoot then return end

        -- Stop physics (prevents snap-back)
        npcRoot.AssemblyLinearVelocity = Vector3.zero
        npcRoot.AssemblyAngularVelocity = Vector3.zero

        -- Anchor briefly
        npcRoot.Anchored = true

        -- TELEPORT VERY CLOSE (0.25 studs)
        npcRoot.CFrame = root.CFrame * CFrame.new(0, 0, -0.25)

        -- Unanchor after short delay (lets kill register)
        task.delay(0.3, function()
            if npcRoot then
                npcRoot.Anchored = false
            end
        end)
    end

    --------------------------------------------------
    -- CLOSE PROMPT
    --------------------------------------------------
    local function closePrompt()
        if not promptOpen then return end

        promptOpen = false

        if promptFrame then
            for i = 1,10 do
                task.wait(0.01)
                promptFrame.BackgroundTransparency = i * 0.1
            end
            promptFrame:Destroy()
            promptFrame = nil
        end

        if blurFrame then
            blurFrame:Destroy()
            blurFrame = nil
        end
    end

    --------------------------------------------------
    -- CREATE PROMPT
    --------------------------------------------------
    local function createPrompt()

        closePrompt()

        local playersList = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                table.insert(playersList, plr)
            end
        end

        if #playersList == 0 then
            StarterGui:SetCore("SendNotification", {
                Title = "Kill Player",
                Text = "No players found!",
                Duration = 3
            })
            return
        end

        local promptPlayers = {}
        for i = 1, math.min(6, #playersList) do
            table.insert(promptPlayers, playersList[i])
        end

        --------------------------------------------------
        -- DARK BACKGROUND
        --------------------------------------------------
        blurFrame = Instance.new("Frame")
        blurFrame.Size = UDim2.new(1,0,1,0)
        blurFrame.BackgroundColor3 = Color3.new(0,0,0)
        blurFrame.BackgroundTransparency = 0.4
        blurFrame.Parent = ScreenGui

        --------------------------------------------------
        -- POSITION BESIDE MAIN UI
        --------------------------------------------------
        promptFrame = Instance.new("Frame")
        promptFrame.Size = UDim2.new(0,200,0,#promptPlayers*30)
        promptFrame.BackgroundColor3 = Color3.fromRGB(50,50,50)
        promptFrame.BorderSizePixel = 0

        -- Position RIGHT of MainFrame
        promptFrame.Position = UDim2.new(
            MainFrame.Position.X.Scale,
            MainFrame.Position.X.Offset + MainFrame.Size.X.Offset + 10,
            MainFrame.Position.Y.Scale,
            MainFrame.Position.Y.Offset
        )

        promptFrame.Parent = ScreenGui
        promptFrame.BackgroundTransparency = 1

        -- Fade in
        task.spawn(function()
            for i = 1,10 do
                task.wait(0.02)
                if promptFrame then
                    promptFrame.BackgroundTransparency = 1 - i*0.1
                end
            end
        end)

        --------------------------------------------------
        -- PLAYER BUTTONS
        --------------------------------------------------
        for i, plr in ipairs(promptPlayers) do

            local plrButton = Instance.new("TextButton")
            plrButton.Size = UDim2.new(1,0,0,30)
            plrButton.Position = UDim2.new(0,0,0,(i-1)*30)
            plrButton.BackgroundColor3 = Color3.fromRGB(70,70,70)
            plrButton.TextColor3 = Color3.fromRGB(255,255,255)
            plrButton.Font = Enum.Font.SourceSans
            plrButton.TextSize = 14
            plrButton.Text = plr.Name
            plrButton.Parent = promptFrame

            plrButton.MouseButton1Click:Connect(function()
                teleportBotToPlayer(plr)
                closePrompt()
            end)
        end

        promptOpen = true
    end

    --------------------------------------------------
    -- BUTTON CLICK
    --------------------------------------------------
    button.MouseButton1Click:Connect(function()
        if promptOpen then
            closePrompt()
        else
            createPrompt()
        end
    end)

    --------------------------------------------------
    -- DELETE KEY CLOSE (FIXED)
    --------------------------------------------------
    UIS.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end

        if input.KeyCode == Enum.KeyCode.Delete then
            closePrompt()
        end
    end)

    --------------------------------------------------
    -- AUTO UPDATE
    --------------------------------------------------
    Players.PlayerAdded:Connect(function()
        if promptOpen then createPrompt() end
    end)

    Players.PlayerRemoving:Connect(function()
        if promptOpen then createPrompt() end
    end)
end

